# Remora Trading Tools - Environment Configuration
# Copy this file to .env and update the values

# ==========================================
# Market Reaper API (RapidAPI)
# ==========================================
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=indonesia-stock-exchange-idx.p.rapidapi.com
API_PLAN=FREE
API_RATE_LIMIT_SECONDS=2
API_MONTHLY_CALL_LIMIT=900
API_DAILY_CALL_LIMIT=100

# ==========================================
# Database Configuration (PostgreSQL)
# ==========================================
POSTGRES_DB=remora
POSTGRES_USER=remora
POSTGRES_PASSWORD=remora_password
DATABASE_URL=postgresql+asyncpg://remora:remora_password@localhost:5432/remora

# ==========================================
# Application Configuration
# ==========================================
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production
LOG_LEVEL=INFO

# ==========================================
# Watchlist (comma-separated)
# ==========================================
WATCHLIST=BUVA,BIPI,VKTR,BUMI,BRMS,ENRG,SUPA,COCO,PTRO,CUAN,IMPC,INDY

# ==========================================
# Broker Classification
# ==========================================
WHALE_BROKERS=AI,BK,YU,BB,AS,SS,CS
RETAIL_BROKERS=YP,XL,PD,XC,CP,AB

# ==========================================
# Sync Configuration
# ==========================================
SYNC_DAILY_HOUR=18
SYNC_DAILY_MINUTE=0
SYNC_WEEKLY_DAY=saturday
SYNC_WEEKLY_HOUR=10

# Data Retention
DATA_RETENTION_MONTHS=12

# ==========================================
# Frontend Configuration
# ==========================================
VITE_API_URL=http://localhost:8000/api/v1